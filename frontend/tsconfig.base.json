{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@web26/services-content": ["packages/services-content/src/index.ts"],
      "@web26/ui-assets": ["packages/ui-assets/src/index.ts"],
      "@web26/ui-library": ["packages/ui-library/src/index.ts"],
      "@web26/ui-tokens": ["packages/ui-tokens/src/index.ts"],
      "@web26/utils": ["packages/utils/src/index.ts"]
    }
  }
}
