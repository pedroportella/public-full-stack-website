# Web26 local environment

WEB26_SITE_URL=http://localhost:3000
WEB26_DRUPAL_BASE_URL=http://localhost:8080
WEB26_DRUPAL_JSONAPI_BASE_URL=http://localhost:8080/jsonapi
WEB26_DEFAULT_LOCALE=en
WEB26_SUPPORTED_LOCALES=en,pt-br

# Drupal local Docker baseline
DRUPAL_DB_NAME=web26
DRUPAL_DB_USER=web26
DRUPAL_DB_PASSWORD=web26
DRUPAL_DB_ROOT_PASSWORD=web26root

# Drupal 7 migration source database exposed inside Drupal as $databases['migrate']['default'].
DRUPAL_MIGRATE_DB_HOST=legacy_database
DRUPAL_MIGRATE_DB_PORT=3306
DRUPAL_MIGRATE_DB_NAME=pedroportella_d7
DRUPAL_MIGRATE_DB_USER=web26_migrate
DRUPAL_MIGRATE_DB_PASSWORD=web26_migrate
DRUPAL_MIGRATE_DB_ROOT_PASSWORD=web26legacyroot

# Legacy public files mounted read-only at /legacy/sites/default/files.
WEB26_LEGACY_FILES_PATH=../../web12/pedroportella.com/public/drupal7/sites/default/files
WEB26_LEGACY_DB_DUMP=../../web12/pedroportella.com/db/pedroportella_d7-20200320-130536.sql.gz
